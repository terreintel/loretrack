# ─────────────────────────────────────────────────────────────
#  LoreTrack – server environment variables
#  Copy this file to server/.env and fill in your values.
#  NEVER commit server/.env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Client origin (used for CORS in development)
CLIENT_URL=http://localhost:5173

# ── Groq API (Whisper transcription) ────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Anthropic API (Claude AI categorisation) ────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Email / SMTP ─────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# Enable 2FA then create an App Password at:
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=LoreTrack Reports <your_email@gmail.com>
